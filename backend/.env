# Backend Server Config
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# Database Config
DATABASE_URL=sqlite:///./easybiz.db

# Auth / JWT Config
JWT_SECRET=super_secret_key_for_development_change_in_production_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Configuration
# Modes: mock, local (Ollama), api (OpenAI/Gemini/Groq)
AI_MODE=mock

# Local AI Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# API-based AI Configuration (OpenAI, Gemini, Groq, etc.)
AI_API_PROVIDER=openai
AI_API_KEY=
AI_API_BASE_URL=
AI_LLM_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small

# RAG Configuration
RAG_CONFIDENCE_THRESHOLD=0.50

# Speech-To-Text Configuration
# Modes: mock, local, api
STT_PROVIDER=mock
MOCK_STT_TRANSCRIPTION=

# WhatsApp Configuration
# Modes: disabled, simulation, cloud_api
WHATSAPP_MODE=simulation
WHATSAPP_VERIFY_TOKEN=easybiz_verify_token_2026
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_NUMBER=

